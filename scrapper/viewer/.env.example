# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=<your_access_key_id>
R2_SECRET_ACCESS_KEY=<your_secret_access_key>
R2_BUCKET=scrapper-assets
R2_PUBLIC_BASE=https://pub-<hash>.r2.dev

# Supabase
SUPABASE_URL=https://<project_ref>.supabase.co
SUPABASE_SERVICE_KEY=eyJ...     # service_role key — server-side only, never in frontend
SUPABASE_ANON_KEY=eyJ...        # anon/public key — safe to expose in frontend JS
